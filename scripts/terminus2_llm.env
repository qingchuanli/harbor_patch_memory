# Shared LLM config for Terminus2 batch runs and smoke tests.
#
# Edit this file before launching:
#   scripts/launch_terminus2_pm.sh
#   scripts/launch_terminus2_baseline.sh
#   scripts/smoke_terminus2_bn_fit_modify.sh
#
# These variables are forwarded to Harbor as --ae LLM_*=... so both the
# Terminus2 agent and patch-memory summarizer can read them.

# Required for OpenAI-compatible endpoints (OpenRouter).
export LLM_API_KEY="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"

# Optional. OpenRouter model id (provider/model).
export LLM_MODEL="openai/gpt-5.5"

# Optional. Required for OpenRouter.
export LLM_BASE_URL="https://openrouter.ai/api/v1"
